# CEREBRAS_API_KEY: Primary AI provider for analytics and audit insights.
# CEREBRAS_MODEL is optional and defaults to llama-3.3-70b
# Get a free key at https://cloud.cerebras.ai (1M tokens/day free tier)
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=llama-3.3-70b

# GEMINI_API_KEY: Optional fallback AI provider when Cerebras is unavailable.
# GEMINI_MODEL is optional and defaults to gemini-3.5-flash.
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-3.5-flash
