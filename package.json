{
  "name": "insightflow",
  "private": false,
  "version": "2.0.0",
  "description": "Premium AI-powered business intelligence workspace with advanced analytics, interactive dashboards, and executive-grade exports",
  "license": "PROPRIETARY",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist','server.js']) fs.rmSync(p,{recursive:true,force:true});\"",
    "lint": "tsc --noEmit",
    "start": "node dist/server.cjs",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^8.0.0",
    "@google/genai": "^2.12.0",
    "@rolldown/pluginutils": "^1.0.0-beta.41",
    "@tailwindcss/vite": "^4.3.3",
    "@vitejs/plugin-react": "^5.2.0",
    "docx": "^9.7.1",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.22.2",
    "framer-motion": "^12.42.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "localforage": "^1.10.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "openai": "^6.47.0",
    "papaparse": "^5.5.4",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "read-excel-file": "^9.3.1",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "svg2pdf.js": "^2.7.0",
    "vite": "^6.2.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.5.2",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.12",
    "glob": "^13.0.6",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.23.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
